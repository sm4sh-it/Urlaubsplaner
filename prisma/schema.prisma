generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Profile {
  id                       String   @id @default(uuid())
  name                     String
  color                    String
  annualLeave              Float
  remainingLeave           Float
  additionalLeave          Float
  remainingLeaveExpiryDate String
  stateCode                String
  startYear                Int      @default(2026)
  workingDays              String   @default("1,2,3,4,5")
  
  entries                  Entry[]
  overrides                ProfileYearOverride[]
  trips                    Trip[]   @relation("ProfileTrips")
  
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Trip {
  id                   String    @id @default(cuid())
  title                String
  startDate            String    // YYYY-MM-DD
  endDate              String    // YYYY-MM-DD
  duration             Int
  
  profiles             Profile[] @relation("ProfileTrips")
  externalParticipants String?
  
  type                 String
  status               String
  
  location             String?
  travelType           String?
  transport            String?
  notes                String?
  
  budget               Float?
  cost                 Float?
  
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model ProfileYearOverride {
  id               String   @id @default(uuid())
  year             Int
  annualLeave      Float?   
  additionalLeave  Float?   
  remainingLeave   Float?   

  profileId        String
  profile          Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, year])
}

model Entry {
  id        String   @id @default(uuid())
  date      String
  type      String
  
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([date, profileId])
}

model HolidayCache {
  id        String   @id @default(cuid())
  date      String
  name      String
  stateCode String
  year      Int

  @@unique([date, stateCode])
}

model VacationCache {
  id        String   @id @default(cuid())
  startDate String
  endDate   String
  name      String
  stateCode String
  year      Int
}
