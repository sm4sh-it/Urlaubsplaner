# ==========================================
# Urlaubsplaner - Environment Variables
# ==========================================

# 1. Authentifizierung
# Setze auf 'false', um die App komplett offen zu betreiben (z.B. im Heimnetzwerk oder hinter einem Reverse Proxy)
# Setze auf 'true', um den Passwortschutz zu aktivieren.
AUTH_ENABLED=true

# Wenn AUTH_ENABLED=true, MUSST du hier ein sicheres Passwort vergeben.
# Bleibt dieses Feld leer, sperrt die App den Zugriff sicherheitshalber komplett!
APP_PASSWORD=sm4sh

# 2. Datenbank (Optional für Docker)
# In der Docker-Umgebung ist dieser Pfad standardmäßig bereits korrekt vorkonfiguriert 
# (file:/app/data/dev.db) und muss in der Regel nicht überschrieben werden.
# Wenn du die App lokal ohne Docker startest, nutzt Prisma automatisch file:./dev.db
# DATABASE_URL="file:./data/dev.db"
